# Groq API (https://console.groq.com/)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase (required for every run; `supabase` is a core dependency)
# Service role key bypasses RLS — required for ingest (inserts).
#
# Gistprism v2 (--from-db): apply schema from 20260411.md, then:
#   sql/news_articles_v2_unique_user_category_url.sql
#   sql/news_article_exclusions_v2.sql
#
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
#
# Source resolve API (`resolve-api`): verify user JWTs. Set at least one of:
# - SUPABASE_URL — required for ES256/RS256 (JWT signing keys); uses JWKS at …/auth/v1/.well-known/jwks.json
# - SUPABASE_JWT_SECRET — legacy HS256 tokens only (Dashboard → Settings → API)
# SUPABASE_JWT_SECRET=
